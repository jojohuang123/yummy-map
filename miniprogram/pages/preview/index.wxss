.page-shell {
  padding-bottom: 168rpx;
}

.loading-card {
  background: var(--bg-soft);
}

.summary-card {
  display: flex;
  justify-content: space-between;
  padding: 22rpx 8rpx;
}

.summary-item {
  flex: 1;
  text-align: center;
}

.summary-val {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.filter-card {
  padding: 20rpx;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 14rpx;
}

.chip-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 20rpx;
  background: var(--bg-soft);
  color: var(--text-secondary);
  border-radius: var(--radius-pill);
  font-size: 24rpx;
}

.chip-active {
  background: var(--accent-primary-soft);
  color: var(--accent-primary);
}

.action-chip {
  background: var(--bg-card);
  color: var(--text-secondary);
}

.item-card {
  padding: 24rpx 22rpx;
}

.item-card-disabled {
  opacity: 0.68;
}

.card-shell {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.item-name {
  flex: 1;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
}

.meta-row {
  margin-top: 10rpx;
}

.tag-row {
  margin-top: 12rpx;
}

.detail-address {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.source-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--text-tertiary);
}

.empty-card {
  text-align: center;
  padding: 72rpx 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 24rpx 28rpx;
  background: rgba(255, 253, 249, 0.96);
  border-top: 1rpx solid var(--line-soft);
  box-shadow: var(--shadow-floating);
  z-index: 20;
  backdrop-filter: blur(10rpx);
}

.footer-text {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.highlight-count {
  color: var(--text-primary);
  font-weight: 700;
}

.footer-button {
  width: 240rpx;
  margin: 0;
}
