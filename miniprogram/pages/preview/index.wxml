<view class="page-shell">
  <view class="page-title">识别结果</view>
  <view class="page-subtitle">先快速筛掉不想留的店，再把值得去的那几家加入地图。</view>

  <block wx:if="{{isEnriching}}">
    <view class="section-card loading-card">
      <view class="section-title">正在补充门店信息</view>
      <view class="muted-text">已提取 {{rawCandidateCount}} 条候选文本，评分和地址正在补齐。</view>
    </view>
  </block>

  <view class="section-card summary-card">
    <view class="summary-item">
       <view class="summary-val">{{rawCandidateCount}}</view>
       <view class="summary-label">提取结果</view>
    </view>
    <view class="summary-item">
       <view class="summary-val">{{summary.total}}</view>
       <view class="summary-label">可导入</view>
    </view>
    <view class="summary-item">
       <view class="summary-val">{{summary.selected}}</view>
       <view class="summary-label">已选择</view>
    </view>
  </view>

  <view class="section-card filter-card">
    <view class="filter-row">
      <block wx:for="{{filters}}" wx:key="id">
        <view
          class="chip {{item.id === filterType ? 'chip-active' : ''}}"
          data-filter="{{item.id}}"
          bindtap="handleFilterChange"
        >
          {{item.label}}
        </view>
      </block>
    </view>

    <view class="chip-row action-row">
      <view class="chip action-chip" bindtap="handleSelectAll">一键全选</view>
      <view class="chip action-chip" bindtap="handleSelectNone">全不选</view>
    </view>
  </view>

  <block wx:if="{{!isEnriching && !items.length}}">
    <view class="section-card empty-card">
      <view class="empty-title">当前筛选下没有门店</view>
      <view class="muted-text">换一个评分范围看看，或者直接查看全部结果。</view>
    </view>
  </block>

  <block wx:for="{{groups}}" wx:key="id">
    <view class="group-header">
      <view class="group-title">{{item.title}}</view>
      <view class="group-hint" wx:if="{{item.hint}}">{{item.hint}}</view>
    </view>

    <block wx:for="{{item.items}}" wx:key="id" wx:for-item="shop">
      <view class="section-card item-card {{shop.cardClass}}">
        <view class="card-shell" data-id="{{shop.id}}" bindtap="handleToggle">
          <block wx:if="{{shop.isMatched}}">
            <view class="checkbox {{shop.selected ? 'checkbox-checked' : ''}}">
              <text wx:if="{{shop.selected}}">✓</text>
            </view>
          </block>
          <block wx:else>
            <view class="checkbox checkbox-disabled"></view>
          </block>

          <view class="card-main">
            <view class="title-row">
              <view class="item-name">{{shop.poiName}}</view>

              <block wx:if="{{shop.isMatched}}">
                <view class="rating-badge {{shop.ratingClass}}">{{shop.ratingBadgeText}}</view>
              </block>
            </view>

            <view class="meta-row">
              <text class="cost-label">人均 {{shop.costLabel}}</text>
            </view>

            <view class="tag-row" wx:if="{{shop.showTag}}">
              <text class="tag-label">{{shop.tagText}}</text>
            </view>

            <view class="detail-address">{{shop.addressLabel}}</view>
            <view class="source-text">{{shop.sourceLabel}}</view>
          </view>
        </view>
      </view>
    </block>
  </block>

  <view class="footer-bar">
    <view class="footer-text">已挑选 <text class="highlight-count">{{summary.selected}}</text> 家店</view>
    <button class="primary-button footer-button" loading="{{isSubmitting}}" disabled="{{isSubmitting || isEnriching || !summary.selected}}" bindtap="handleConfirm">加入我的地图</button>
  </view>
</view>
