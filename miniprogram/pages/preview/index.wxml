<view class="page-shell">
  <view class="page-title">识别结果</view>
  <view class="page-subtitle">帮你自动提取了可能是商铺的名字。勾选你想导入到地图的心动小店吧！</view>

  <block wx:if="{{isEnriching}}">
    <view class="section-card">
      <view class="section-title">🔍 正在补充信息...</view>
      <view class="muted-text">已提取 {{rawCandidateCount}} 条候选文本，努力联网查找神仙评分中。</view>
    </view>
  </block>

  <view class="section-card summary-card">
    <view class="summary-item">
       <view class="summary-val">{{rawCandidateCount}}</view>
       <view class="summary-label">提取结果</view>
    </view>
    <view class="summary-item">
       <view class="summary-val">{{summary.total}}</view>
       <view class="summary-label">可导入</view>
    </view>
    <view class="summary-item">
       <view class="summary-val">{{summary.selected}}</view>
       <view class="summary-label">已选择</view>
    </view>
  </view>



  <view class="section-card">
    <view class="chip-row">
      <view class="chip action-chip" bindtap="handleSelectAll">一键全选</view>
      <view class="chip action-chip" bindtap="handleSelectNone">全不选</view>
    </view>
  </view>

  <block wx:if="{{!isEnriching && !items.length}}">
    <view class="section-card empty-card">
      <view class="empty-title">当前筛选下没有门店</view>
      <view class="muted-text">可以切换一下上方的评分过滤条件。</view>
    </view>
  </block>

  <block wx:for="{{items}}" wx:key="id">
    <view class="section-card item-card {{item.cardClass}}">
      <view class="card-header" data-id="{{item.id}}" bindtap="handleToggle">
        <block wx:if="{{item.matchStatus === 'matched'}}">
          <view class="checkbox {{item.selected ? 'checkbox-checked' : ''}}">
            <text wx:if="{{item.selected}}">✓</text>
          </view>
        </block>
        <block wx:else>
          <view class="checkbox checkbox-disabled"></view>
        </block>

        <view class="card-title-group">
          <view class="item-name">{{item.poiName}}</view>
          <view class="muted-text">来源词：{{item.inputName}}</view>
        </view>

        <!-- 评分徽章化 -->
        <block wx:if="{{item.matchStatus === 'matched'}}">
          <view class="rating-badge {{item.ratingClass}}">
            <text wx:if="{{item.rating}}">⭐ {{item.rating}}</text>
            <text wx:else>{{item.ratingLabel}}</text>
          </view>
        </block>
      </view>

      <view class="detail-row">
        <text class="tag-label">{{item.topTagsLabel}}</text>
        <text class="cost-label">人均 {{item.costLabel}}</text>
      </view>
      <view class="detail-address">📍 {{item.addressLabel}}</view>
    </view>
  </block>

  <view class="footer-bar">
    <view class="footer-text">已挑选 <text class="highlight-count">{{summary.selected}}</text> 家店</view>
    <button class="primary-button footer-button" loading="{{isSubmitting}}" disabled="{{isSubmitting || isEnriching || !summary.selected}}" bindtap="handleConfirm">加入我的地图</button>
  </view>
</view>
