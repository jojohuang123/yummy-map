.page-shell {
  padding-bottom: 44rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.edit-toggle {
  padding: 8rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 18rpx;
  background: var(--bg-soft);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
}

.batch-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.batch-delete-btn {
  min-width: 160rpx;
  margin: 0;
}

.list-card {
  padding: 22rpx;
}

.is-edit-mode {
  background: var(--bg-card);
}

.card-row {
  display: flex;
  align-items: flex-start;
}

.list-checkbox {
  margin-right: 14rpx;
  margin-top: 4rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title-group {
  justify-content: flex-start;
}

.item-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.35;
  font-weight: 700;
  color: var(--text-primary);
}

.list-detail-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.list-address {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.import-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.list-button-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.list-button-row .card-button {
  flex: 1;
  margin: 0;
}

.empty-card {
  text-align: center;
  padding: 72rpx 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
