/* ============================================
   美食地图助手 - 列表页样式
   精致可爱美食家手帐风格
   ============================================ */

/* ===== 页面容器 ===== */
page {
  background: var(--bg-primary);
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
  background: var(--bg-primary);
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

/* ===== 列表头部 ===== */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.edit-toggle {
  font-size: 28rpx;
  color: var(--color-coral);
  padding: 8rpx 20rpx;
  background: rgba(255, 123, 107, 0.1);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

/* ===== 批量操作栏 ===== */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

.batch-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.batch-delete-btn {
  background: var(--color-strawberry);
  color: #fff;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: var(--radius-md);
}

.batch-delete-btn[disabled] {
  background: #D4CBC0;
}

/* ===== 卡片样式 ===== */
.section-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-card);
  border: 2rpx solid var(--border-light);
  /* 淡淡的装饰圆点背景 */
  background-image: radial-gradient(
    circle at 5% 5%,
    rgba(255, 123, 107, 0.05) 2rpx,
    transparent 2rpx
  );
  background-size: 20rpx 20rpx;
}

.list-card {
  padding: 20rpx;
}

.list-card.is-edit-mode {
  padding: 16rpx;
  background: rgba(255, 123, 107, 0.03);
}

.card-row {
  display: flex;
  align-items: flex-start;
}

/* ===== 复选框 ===== */
.checkbox {
  font-size: 28rpx;
  border: 2rpx solid var(--border-light);
  width: 44rpx;
  height: 44rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-card);
  margin-top: 4rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.checkbox-checked {
  background: var(--color-coral);
  border-color: var(--color-coral);
  color: white;
}

/* ===== 卡片内容 ===== */
.card-content {
  flex: 1;
  min-width: 0;
}

.item-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.list-detail-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.tag-label {
  color: var(--text-secondary);
  max-width: 320rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: rgba(255, 123, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: 24rpx;
}

.cost-label {
  color: var(--color-strawberry);
  font-weight: 600;
  font-size: 26rpx;
}

.list-address {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.import-time {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* ===== 按钮行 ===== */
.button-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.card-button {
  flex: 1;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  background: var(--bg-card);
  color: var(--color-coral);
  border: 2rpx solid var(--border-light);
  border-radius: var(--radius-md);
  margin: 0;
}

.card-button::after {
  border: none;
}

.card-button:active {
  background: rgba(255, 123, 107, 0.08);
}

/* ===== 评分徽章 ===== */
.rating-gold {
  background: linear-gradient(135deg, var(--color-honey-gold), var(--color-honey-dark));
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
  box-shadow: var(--shadow-honey);
}

.rating-green {
  background: linear-gradient(135deg, var(--color-mint), #4AB89C);
  color: #FFFFFF;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(91, 200, 175, 0.3);
}

.rating-gray {
  background: linear-gradient(135deg, #E8E0D8, #D4CBC0);
  color: var(--text-secondary);
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

/* ===== 卡片头部组 ===== */
.card-title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* ===== 空状态 ===== */
.empty-card {
  text-align: center;
  padding: 80rpx 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx dashed var(--border-light);
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* ===== 次要按钮 ===== */
.secondary-button {
  background: var(--bg-card);
  color: var(--color-coral);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  border: 2rpx solid var(--color-coral);
  text-align: center;
  padding: 0 24rpx;
}

.secondary-button::after {
  border: none;
}

.secondary-button:active {
  background: rgba(255, 123, 107, 0.08);
}

/* ===== 危险按钮 ===== */
.danger-button {
  background: var(--color-strawberry);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}

.danger-button::after {
  border: none;
}

.danger-button[disabled] {
  background: #D4CBC0;
}
