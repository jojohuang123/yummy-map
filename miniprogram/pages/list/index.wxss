.page-shell {
  padding-bottom: 44rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.edit-toggle {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 8rpx 14rpx;
  font-size: 26rpx;
  color: var(--color-primary);
  background: rgba(217, 124, 98, 0.08);
  border-radius: var(--radius-pill);
}

.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx 14rpx 16rpx;
  margin-bottom: 18rpx;
  background: var(--bg-soft);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-md);
}

.batch-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.3;
}

.batch-delete-btn {
  min-width: 160rpx;
  margin: 0;
}

.list-card {
  padding: 24rpx;
}

.is-edit-mode {
  background: var(--bg-card);
}

.card-row {
  display: flex;
  align-items: flex-start;
}

.list-checkbox {
  margin-right: 14rpx;
  margin-top: 4rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title-group {
  justify-content: flex-start;
  width: 100%;
}

.item-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
}

.rating-badge {
  flex-shrink: 0;
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.list-detail-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-top: 10rpx;
  line-height: 1.4;
}

.list-address {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.import-time {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.list-button-row {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  align-items: center;
}

.list-button-row .card-button {
  flex: 1;
  margin: 0;
}

.empty-card {
  text-align: center;
  padding: 72rpx 30rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}
