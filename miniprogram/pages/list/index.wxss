
.header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.list-count { font-size: 26rpx; color: #666; }
.manage-btn { font-size: 26rpx; color: #07C160; }
.item-card { display: flex; align-items: flex-start; gap: 16rpx; }
.item-content { flex: 1; }
.item-name { font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; }
.detail-row { display: flex; gap: 16rpx; font-size: 24rpx; color: #666; margin-bottom: 8rpx; }
.detail-address { font-size: 24rpx; color: #999; }
.checkbox { font-size: 32rpx; border: 2rpx solid #ddd; width: 40rpx; height: 40rpx; display: inline-flex; align-items: center; justify-content: center; margin-top: 8rpx; }
.checkbox-checked { background: #07C160; border-color: #07C160; color: white; }
.action-bar { display: flex; gap: 16rpx; margin-top: 24rpx; }
.action-btn { flex: 1; }
.empty-card { text-align: center; padding: 64rpx 32rpx; }
.empty-title { font-size: 32rpx; font-weight: bold; margin-bottom: 16rpx; }

/* 评分类样式 */
.rating-gold {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: bold;
}
.rating-green {
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.rating-gray {
  background: #e0e0e0;
  color: #999;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.list-detail-row { display: flex; align-items: center; gap: 16rpx; }
.list-address { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.import-time { font-size: 22rpx; color: #B8A696; margin-top: 8rpx; }
.list-button-row { display: flex; gap: 12rpx; margin-top: 16rpx; }
.list-button-row .card-button { flex: 1; font-size: 24rpx; height: 64rpx; line-height: 64rpx; padding: 0; }
.list-card { padding: 24rpx; }
.list-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24rpx; }
.edit-toggle { font-size: 28rpx; color: #07C160; }
.batch-bar { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; margin-bottom: 16rpx; }
.batch-left { display: flex; align-items: center; gap: 12rpx; }
.batch-text { font-size: 26rpx; color: #666; }
.batch-delete-btn { background: #FF6B6B; color: #fff; font-size: 26rpx; height: 64rpx; line-height: 64rpx; padding: 0 24rpx; margin: 0; }
.batch-delete-btn[disabled] { background: #ccc; }
.danger-button::after { border: none; }
.is-edit-mode { padding: 16rpx; }
.list-checkbox { margin-right: 16rpx; }
.card-row { display: flex; align-items: flex-start; }
