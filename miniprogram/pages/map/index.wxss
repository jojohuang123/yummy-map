/* ============================================
   美食地图助手 - 地图页样式
   精致可爱美食家手帐风格
   ============================================ */

/* ===== 页面容器 ===== */
.map-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  padding-bottom: 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
  background: var(--bg-primary);
}

/* ===== 顶部栏：城市选择器 + 搜索框 ===== */
.map-top-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.city-picker {
  flex-shrink: 0;
}

/* 城市胶囊 - 珊瑚色边框 */
.city-pill {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  height: 64rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--color-coral);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-shadow: var(--shadow-soft);
}

.picker-arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--color-coral);
}

/* 搜索框 - 奶油色背景 */
.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #F5F0EB;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 26rpx;
  color: var(--color-coral);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

/* ===== 统计栏 ===== */
.map-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
  padding: 12rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
}

.map-stats .icon {
  margin-right: 6rpx;
}

.highlight-count-small {
  color: var(--color-honey);
  font-weight: bold;
}

.map-link {
  color: var(--color-coral);
  font-weight: 500;
}

/* ===== 地图面板 ===== */
.map-panel {
  flex: 1;
  width: 100%;
  margin-bottom: 0;
  min-height: 400rpx;
  max-height: calc(100vh - 280rpx);
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 2rpx solid var(--border-light);
}

/* ===== 底部可拖动面板 ===== */
.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-primary) 100%);
  border-radius: 40rpx 40rpx 0 0;
  box-shadow: 0 -8rpx 32rpx rgba(255, 123, 107, 0.12);
  z-index: 100;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* 拖动指示条 - 渐变小圆点 */
.drag-handle {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 12rpx;
  flex-shrink: 0;
}

.drag-indicator {
  width: 100rpx;
  height: 12rpx;
  background: linear-gradient(90deg,
    #FFD4C4 0%,
    var(--color-coral-light) 25%,
    #FFD4C4 50%,
    var(--color-coral-light) 75%,
    #FFD4C4 100%
  );
  border-radius: 6rpx;
}

/* 当前商家卡片区域 */
.current-store-section {
  flex-shrink: 0;
  padding: 0 24rpx;
}

/* 商家卡片 - 淡粉色圆点装饰背景 */
.current-store-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 24rpx;
  border: 2rpx solid var(--border-light);
  box-shadow: var(--shadow-card);
  /* 淡淡的装饰圆点背景 */
  background-image: radial-gradient(
    circle at 10% 10%,
    rgba(255, 123, 107, 0.06) 3rpx,
    transparent 3rpx
  );
  background-size: 32rpx 32rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.store-name {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text-primary);
  flex: 1;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  flex-wrap: wrap;
}

.tag-label {
  color: var(--text-secondary);
  max-width: 380rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: rgba(255, 123, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
}

.cost-label {
  color: var(--color-strawberry);
  font-weight: 600;
  font-size: 26rpx;
}

.address-row {
  font-size: 24rpx;
  color: var(--text-muted);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-left: 4rpx;
}

.address-row::before {
  content: '📍';
  margin-right: 8rpx;
}

/* ===== 收起提示 ===== */
.pull-up-hint {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 12rpx 0;
  flex-shrink: 0;
}

.hint-text {
  font-size: 24rpx;
  color: var(--text-muted);
}

.hint-text::before {
  content: '↑';
  margin-right: 8rpx;
  color: var(--color-coral);
}

/* ===== 附近商家区域 ===== */
.nearby-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.nearby-header {
  padding: 16rpx 24rpx 12rpx;
  border-top: 1rpx dashed var(--border-light);
  flex-shrink: 0;
}

.nearby-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.nearby-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

.nearby-list {
  flex: 1;
  padding: 0 24rpx;
  min-height: 0;
}

/* 附近商家列表项 - 可爱虚线分隔 */
.nearby-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 2rpx dashed var(--border-light);
}

.nearby-item:last-child {
  border-bottom: none;
}

.nearby-item.active {
  background: rgba(255, 123, 107, 0.06);
  margin: 0 -12rpx;
  padding: 18rpx 12rpx;
  border-radius: var(--radius-md);
  border-bottom: none;
}

.nearby-info {
  flex: 1;
  min-width: 0;
}

.nearby-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
}

.nearby-rating {
  color: var(--color-honey);
  font-weight: 500;
}

/* 距离标签 - 薄荷绿 */
.nearby-distance {
  color: var(--color-mint);
  background: rgba(91, 200, 175, 0.12);
  padding: 2rpx 10rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.nearby-tags {
  font-size: 22rpx;
  color: var(--text-muted);
  max-width: 180rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}

/* 空状态 */
.nearby-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 24rpx;
  flex: 1;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-muted);
  text-align: center;
}

/* ===== 评分徽章 - 蜂蜜金色渐变 ===== */
.rating-badge {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  font-weight: 600;
}

.rating-badge.rating-gold {
  background: linear-gradient(135deg, var(--color-honey-gold), var(--color-honey-dark));
  color: #FFFFFF;
  box-shadow: var(--shadow-honey);
}

.rating-badge.rating-green {
  background: linear-gradient(135deg, var(--color-mint), #4AB89C);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(91, 200, 175, 0.3);
}

.rating-badge.rating-gray {
  background: linear-gradient(135deg, #E8E0D8, #D4CBC0);
  color: var(--text-secondary);
  box-shadow: none;
}

/* ===== 地图空状态 ===== */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  line-height: 1.6;
}

/* ===== 标记选择动画 ===== */
@keyframes markerBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.15); }
}

.marker-selected {
  animation: markerBounce 0.3s ease-in-out;
}
