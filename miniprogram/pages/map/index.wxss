.map-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
  overflow: hidden;
  position: relative;
}

.map-top-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 14rpx;
  flex-shrink: 0;
  align-items: center;
}

.city-picker {
  flex-shrink: 0;
}

.city-pill {
  min-width: 106rpx;
  height: 76rpx;
  padding: 0 22rpx;
  background: rgba(255, 253, 249, 0.84);
  border: 1rpx solid rgba(217, 124, 98, 0.12);
  border-radius: var(--radius-pill);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  color: var(--text-primary);
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(52, 42, 36, 0.025);
}

.picker-arrow {
  color: var(--text-tertiary);
  font-size: 20rpx;
}

.map-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 0 6rpx 12rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.stats-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.35;
}

.highlight-count-small {
  color: #D4814F;
  font-weight: 700;
  font-size: 32rpx;
}

.map-link {
  color: var(--text-secondary);
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 0;
}

.map-panel {
  flex: 1;
  width: 100%;
  min-height: 400rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(52, 42, 36, 0.04);
  border: 1rpx solid rgba(230, 217, 203, 0.52);
}

.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  background: rgba(255, 253, 249, 0.985);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  box-shadow: 0 -6rpx 16rpx rgba(52, 42, 36, 0.06);
  z-index: 50;
  overflow: hidden;
  backdrop-filter: blur(14rpx);
  box-sizing: border-box;
  padding-bottom: 24rpx;
}

.drag-handle {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 14rpx 0 10rpx;
  flex-shrink: 0;
}

.drag-indicator {
  width: 88rpx;
  height: 8rpx;
  border-radius: var(--radius-pill);
  background: #D9CCC0;
}

.current-store-section {
  padding: 0 24rpx;
  flex-shrink: 0;
}

.current-store-section-expanded {
  padding: 0 24rpx 8rpx;
}

.current-store-card {
  background: var(--bg-card);
  border: 1rpx solid var(--line-soft);
  border-radius: 28rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(52, 42, 36, 0.045);
}

.current-store-card-compact {
  padding: 18rpx 20rpx;
  border-radius: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(52, 42, 36, 0.04);
}

.current-store-card-compact .card-header {
  margin-bottom: 6rpx;
}

.current-store-card-compact .card-title-group {
  gap: 10rpx;
}

.current-store-card-compact .store-name {
  font-size: 28rpx;
  line-height: 1.35;
}

.current-store-card-compact .score-badge {
  min-height: 52rpx;
  padding: 0 16rpx;
  font-size: 24rpx;
}

.current-store-card-compact .meta-row {
  margin-top: 0;
  gap: 10rpx;
}

.current-store-card-compact .tag-row {
  margin-top: 8rpx;
}

.current-store-card-compact .address-row {
  margin-top: 8rpx;
  font-size: 22rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.card-title-group {
  width: 100%;
  align-items: flex-start;
}

.store-name {
  flex: 1;
  min-width: 0;
  font-size: 34rpx;
  line-height: 1.28;
  font-weight: 700;
  color: var(--text-primary);
}

.score-badge {
  flex-shrink: 0;
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 18rpx;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: none;
}

.card-body {
  display: flex;
  flex-direction: column;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 2rpx;
  line-height: 1.4;
}

.business-area {
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-tertiary);
}

.distance-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 12rpx;
  min-height: 40rpx;
  border-radius: var(--radius-pill);
  background: rgba(217, 124, 98, 0.08);
  color: #B86A59;
  font-size: 21rpx;
  font-weight: 600;
  line-height: 1;
}

.tag-row {
  margin-top: 10rpx;
}

.tag-label {
  display: inline-flex;
  align-items: center;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.2;
  background: rgba(241, 232, 221, 0.8);
}

.address-row {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 16rpx;
  min-height: 88rpx;
}

.card-cta {
  flex: 1;
  margin: 0;
}

.remove-link {
  display: inline-flex;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  color: var(--text-secondary);
  font-size: 24rpx;
  line-height: 1.25;
  min-height: 88rpx;
  padding: 0 6rpx;
  white-space: nowrap;
}

.pull-up-hint {
  display: flex;
  justify-content: center;
  padding: 6rpx 0 8rpx;
}

.hint-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
  line-height: 1.2;
}

.nearby-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 340rpx;
}

.nearby-header {
  padding: 12rpx 24rpx 8rpx;
  border-top: 1rpx solid var(--line-soft);
  flex-shrink: 0;
}

.nearby-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.nearby-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.nearby-list {
  flex: 1;
  min-height: 340rpx;
  height: 400rpx;
  padding: 0 24rpx 8rpx;
  box-sizing: border-box;
}

.nearby-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
  padding: 15rpx 0;
  border-bottom: 1rpx solid var(--line-soft);
}

.nearby-item:last-child {
  border-bottom: none;
}

.nearby-info {
  flex: 1;
  min-width: 0;
}

.nearby-name {
  font-size: 27rpx;
  font-weight: 600;
  line-height: 1.32;
  color: var(--text-primary);
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
  line-height: 1.3;
}

.nearby-rating {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 12rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
}

.nearby-distance {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 600;
  line-height: 1.3;
}

.nearby-tags {
  max-width: 168rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-tertiary);
  text-align: right;
  padding-top: 1rpx;
}

.nearby-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 30rpx 24rpx 40rpx;
}

.empty-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx;
}

.empty-illustration {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #EFE5DA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: var(--color-primary);
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
}
