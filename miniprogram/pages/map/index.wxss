.map-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
  overflow: hidden;
  position: relative;
}

.map-top-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
  flex-shrink: 0;
}

.city-picker {
  flex-shrink: 0;
}

.map-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 0 2rpx 14rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.highlight-count-small {
  color: var(--text-primary);
  font-weight: 700;
}

.map-link {
  color: var(--text-secondary);
  font-size: 24rpx;
}

.map-panel {
  flex: 1;
  width: 100%;
  min-height: 400rpx;
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  background: rgba(255, 253, 249, 0.98);
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  box-shadow: var(--shadow-floating);
  z-index: 50;
  overflow: hidden;
  backdrop-filter: blur(14rpx);
}

.drag-handle {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 12rpx;
  flex-shrink: 0;
}

.drag-indicator {
  width: 88rpx;
  height: 8rpx;
  border-radius: var(--radius-pill);
  background: #D9CCC0;
}

.current-store-section {
  padding: 0 24rpx;
  flex-shrink: 0;
}

.current-store-card {
  background: var(--bg-card);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-lg);
  padding: 22rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.store-name {
  flex: 1;
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 700;
  color: var(--text-primary);
}

.card-body {
  display: flex;
  flex-direction: column;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.business-area {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.tag-row {
  margin-top: 12rpx;
}

.address-row {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--text-secondary);
}

.card-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.card-cta {
  flex: 1;
  margin: 0;
}

.remove-link {
  flex-shrink: 0;
  color: var(--text-tertiary);
  font-size: 24rpx;
}

.pull-up-hint {
  display: flex;
  justify-content: center;
  padding: 12rpx 0 16rpx;
}

.hint-text {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.nearby-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.nearby-header {
  padding: 16rpx 24rpx 12rpx;
  border-top: 1rpx solid var(--line-soft);
  flex-shrink: 0;
}

.nearby-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.nearby-hint {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.nearby-list {
  flex: 1;
  min-height: 0;
  padding: 0 24rpx 6rpx;
}

.nearby-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid var(--line-soft);
}

.nearby-item:last-child {
  border-bottom: none;
}

.nearby-info {
  flex: 1;
  min-width: 0;
}

.nearby-name {
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.35;
  color: var(--text-primary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.nearby-rating {
  font-size: 22rpx;
  color: #8E6925;
}

.nearby-distance {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.nearby-tags {
  max-width: 170rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: var(--text-tertiary);
  text-align: right;
}

.nearby-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 30rpx 24rpx 40rpx;
}

.empty-text {
  font-size: 24rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx;
}

.empty-illustration {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #EFE5DA;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.empty-dot {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: var(--accent-primary);
}

.empty-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: var(--text-secondary);
  margin-bottom: 30rpx;
}
