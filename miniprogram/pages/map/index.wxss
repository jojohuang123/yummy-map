.map-shell {
  height: 100vh;
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  padding-bottom: 0;
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.map-top-bar {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
  flex-shrink: 0;
}

.city-picker { flex-shrink: 0; }
.city-pill {
  display: flex;
  align-items: center;
  padding: 0 16rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #eee;
  font-size: 28rpx;
}
.picker-arrow { margin-left: 8rpx; font-size: 20rpx; color: #999; }

.search-bar {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  padding: 0 16rpx;
  height: 72rpx;
  gap: 8rpx;
}
.search-icon { font-size: 28rpx; }
.search-input { flex: 1; font-size: 28rpx; }
.search-clear { font-size: 24rpx; color: #ccc; padding: 8rpx; }

.map-stats {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}
.highlight-count-small { color: #07C160; font-weight: bold; }
.map-link { color: #07C160; }

/* 地图 */
.map-panel {
  flex: 1;
  width: 100%;
  margin-bottom: 0;
  min-height: 400rpx;
  max-height: calc(100vh - 280rpx);
}

/* ========== 底部可拖动面板 ========== */
.bottom-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.drag-handle {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0 8rpx;
  flex-shrink: 0;
}
.drag-indicator {
  width: 80rpx;
  height: 8rpx;
  background: #ddd;
  border-radius: 4rpx;
}

/* 当前商家卡片区域 */
.current-store-section {
  flex-shrink: 0;
}

.current-store-card {
  margin: 0 24rpx;
  background: #FFF9F1;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #FFE4C4;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.card-title-group {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.store-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F1A17;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.info-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
}

.tag-label {
  color: #666;
  max-width: 400rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cost-label {
  color: #FF6B6B;
  font-weight: 500;
}

.address-row {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 收起提示 */
.pull-up-hint {
  display: flex;
  justify-content: center;
  padding: 12rpx 0;
  flex-shrink: 0;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
}

/* 附近商家区域 */
.nearby-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}

.nearby-header {
  padding: 16rpx 24rpx 12rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
}

.nearby-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1F1A17;
  margin-bottom: 4rpx;
}

.nearby-hint {
  font-size: 24rpx;
  color: #666;
}

.nearby-list {
  flex: 1;
  padding: 0 24rpx;
  min-height: 0;
}

.nearby-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.nearby-item:last-child {
  border-bottom: none;
}

.nearby-info {
  flex: 1;
  min-width: 0;
}

.nearby-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1F1A17;
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nearby-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 22rpx;
  color: #999;
}

.nearby-rating {
  color: #FF9500;
}

.nearby-distance {
  color: #07C160;
}

.nearby-tags {
  font-size: 22rpx;
  color: #999;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: right;
}

/* 空状态 */
.nearby-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48rpx 24rpx;
  flex: 1;
}

.empty-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 评分徽章 */
.rating-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}
.rating-gold {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
}
.rating-green {
  background: linear-gradient(135deg, #07C160, #06AD56);
  color: #fff;
}
.rating-gray {
  background: linear-gradient(135deg, #ccc, #999);
  color: #fff;
}

/* 空状态 */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 48rpx;
  text-align: center;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1F1A17;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 32rpx;
}
