<view class="page-shell map-shell">
  <view class="map-top-bar">
    <picker
      class="city-picker"
      range="{{cityList}}"
      range-key="name"
      value="{{cityIndex}}"
      bindchange="handleCityChange"
    >
      <view class="city-pill">
        <text>{{cityList[cityIndex].name}}</text>
        <text class="picker-arrow">▾</text>
      </view>
    </picker>

    <view class="search-bar">
      <text class="search-icon">搜</text>
      <input
        class="search-input"
        placeholder="搜索店名或菜系"
        value="{{searchKeyword}}"
        bindinput="handleSearchInput"
        confirm-type="search"
      />
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="handleSearchClear">✕</view>
    </view>
  </view>

  <view class="map-stats">
    <text class="stats-text">
      已收藏 <text class="highlight-count-small">{{filteredFavorites.length}}</text> 家
      <text wx:if="{{searchKeyword || cityList[cityIndex].adcode}}">（筛选结果）</text>
    </text>
    <view class="map-link" bindtap="handleGoList">查看清单</view>
  </view>

  <block wx:if="{{favorites.length}}">
    <map
      class="map-panel"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      include-points="{{includePoints}}"
      bindmarkertap="handleMarkerTap"
      bindcallouttap="handleMarkerTap"
      show-location="true"
    />

    <view
      class="bottom-panel"
      style="height: {{panelHeight}}rpx;"
      bindtouchstart="onPanelTouchStart"
      bindtouchmove="onPanelTouchMove"
      bindtouchend="onPanelTouchEnd"
    >
      <view class="drag-handle" bindtap="togglePanel">
        <view class="drag-indicator"></view>
      </view>

      <view class="current-store-section {{panelExpanded ? 'current-store-section-expanded' : ''}}" wx:if="{{selectedFavorite}}">
        <view class="current-store-card {{panelExpanded ? 'current-store-card-compact' : ''}}">
          <view class="card-header">
            <view class="card-title-group">
              <view class="store-name">{{selectedFavorite.name}}</view>
              <view class="rating-badge score-badge {{selectedFavorite.ratingClass}}" wx:if="{{selectedFavorite.ratingLabel !== '-'}}">{{selectedFavorite.ratingBadgeText}}</view>
            </view>
          </view>

          <view class="card-body">
            <view class="meta-row">
              <text class="cost-label">人均 {{selectedFavorite.costLabel}}</text>
              <text class="distance-pill" wx:if="{{selectedFavorite.nearestDistanceText}}">附近 {{selectedFavorite.nearestDistanceText}}</text>
              <text class="business-area" wx:if="{{selectedFavorite.businessArea}}">{{selectedFavorite.businessArea}}</text>
            </view>

            <view class="tag-row">
              <text class="tag-label">{{selectedFavorite.topTagsLabel}}</text>
            </view>

            <view class="address-row">{{selectedFavorite.address}}</view>

            <view class="card-actions" wx:if="{{!panelExpanded}}">
              <button class="primary-button card-cta" bindtap="handleNavigate">导航到这</button>
              <view class="text-button remove-link" bindtap="handleRemoveFavorite">从收藏移除</view>
            </view>
          </view>
        </view>
      </view>

      <view class="nearby-section" wx:if="{{panelExpanded && nearbyStores.length > 0}}">
        <view class="nearby-header">
          <view class="nearby-title">附近商家</view>
        </view>

        <scroll-view class="nearby-list" scroll-y enhanced show-scrollbar="false">
          <view
            class="nearby-item"
            wx:for="{{nearbyStores}}"
            wx:key="id"
            bindtap="onSelectNearbyStore"
            data-id="{{item.id}}"
          >
            <view class="nearby-info">
              <view class="nearby-name">{{item.name}}</view>
              <view class="nearby-meta">
                <text class="nearby-rating rating-badge {{item.ratingClass}}" wx:if="{{item.rating}}">{{item.ratingBadgeText}}</text>
                <text class="nearby-distance">{{item.distanceText}}</text>
              </view>
            </view>
            <view class="nearby-tags">{{item.topTagsLabel}}</view>
          </view>
        </scroll-view>
      </view>

      <view class="nearby-empty" wx:if="{{panelExpanded && nearbyStores.length === 0 && selectedFavorite}}">
        <text class="empty-text">这片区域没有其他收藏商家了</text>
      </view>

      <view class="pull-up-hint" wx:if="{{!panelExpanded}}">
        <text class="hint-text">上拉查看附近商家</text>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <view class="empty-illustration">
        <view class="empty-dot"></view>
      </view>
      <view class="empty-title">地图空空如也</view>
      <view class="empty-desc">先导入几家想去的店，地图上才会慢慢长出你的美食路线。</view>
      <button class="primary-button" bindtap="handleGoImport">去导入美食截图</button>
    </view>
  </block>
</view>
