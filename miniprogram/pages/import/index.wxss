.import-shell {
  position: relative;
  padding-top: 28rpx;
  padding-bottom: 88rpx;
  background:
    radial-gradient(circle at top right, rgba(217, 124, 98, 0.14), transparent 28%),
    linear-gradient(180deg, #F8F1E8 0%, #F7F2EA 100%);
}

.import-hero {
  padding: 24rpx 0 12rpx;
}

.hero-kicker {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 8rpx 22rpx rgba(217, 124, 98, 0.1);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.hero-collage {
  position: relative;
  height: 394rpx;
  margin-bottom: 30rpx;
  padding: 22rpx;
  border-radius: 34rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.75), transparent 34%),
    linear-gradient(180deg, rgba(255, 249, 241, 0.96) 0%, rgba(252, 244, 233, 0.94) 100%);
  border: 1rpx solid rgba(217, 124, 98, 0.1);
  overflow: hidden;
}

.hero-collage::before {
  content: "";
  position: absolute;
  inset: -20% auto auto -10%;
  width: 360rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.36) 0%, rgba(255, 255, 255, 0) 72%);
  animation: warmthShift 8s ease-in-out infinite;
  pointer-events: none;
}

.hero-collage::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at 78% 18%, rgba(217, 124, 98, 0.12), transparent 22%);
  animation: sheenDrift 9s ease-in-out infinite;
  pointer-events: none;
}

.collage-warmth {
  position: absolute;
  border-radius: 50%;
  filter: blur(12rpx);
  opacity: 0.85;
}

.warmth-one {
  width: 120rpx;
  height: 120rpx;
  left: 196rpx;
  top: 70rpx;
  background: radial-gradient(circle, rgba(255, 198, 120, 0.45) 0%, rgba(255, 198, 120, 0) 72%);
  animation: glowPulse 4.8s ease-in-out infinite;
}

.warmth-two {
  width: 150rpx;
  height: 110rpx;
  right: 84rpx;
  top: 92rpx;
  background: radial-gradient(circle, rgba(255, 181, 154, 0.24) 0%, rgba(255, 181, 154, 0) 75%);
  animation: glowPulse 5.4s ease-in-out infinite 1.2s;
}

.sticker-card {
  position: absolute;
  background: rgba(255, 255, 255, 0.94);
  border-radius: 28rpx;
  box-shadow: 0 14rpx 32rpx rgba(52, 42, 36, 0.08);
  padding: 16rpx 16rpx 18rpx;
}

.sticker-title {
  margin-top: 10rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.sticker-note {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
}

.hotpot-card {
