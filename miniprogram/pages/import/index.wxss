  z-index: 3;
  padding: 10rpx 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 22rpx rgba(52, 42, 36, 0.06);
  color: var(--color-primary);
  font-size: 22rpx;
  animation: tagBreath 4.6s ease-in-out infinite;
}

.tag-comment {
  left: 28rpx;
