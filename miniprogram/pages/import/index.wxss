.picker-value {
  height: 88rpx;
  border-radius: 24rpx;
  background: #efe2d0;
  padding: 0 24rpx;
  line-height: 88rpx;
  font-size: 28rpx;
}

.dev-card .muted-text + .muted-text {
  margin-top: 10rpx;
}

.text-area {
  width: 100%;
  min-height: 280rpx;
  background: #f7efe5;
  border-radius: 24rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.image-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.image-slot {
  width: 206rpx;
  height: 206rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.upload-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx dashed #c5b29b;
  background: #f7efe5;
}

.upload-text {
  font-size: 26rpx;
  color: #7c7067;
}

.filled-slot {
  position: relative;
  background: #e8ddcf;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-button {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  margin: 0;
  padding: 0 18rpx;
}

.status-card,
.error-card {
  margin-top: 24rpx;
}

.error-text {
  color: #9f2a20;
  font-size: 26rpx;
}

.import-map-button {
  margin-top: 20rpx;
}
