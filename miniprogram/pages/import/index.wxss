}

.hero-copy {
  margin-bottom: 18rpx;
}

.accent-title {
  color: var(--color-primary);
}

.entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx 22rpx 26rpx 24rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at top right, rgba(240, 168, 111, 0.14), transparent 24%),
    linear-gradient(135deg, rgba(255, 253, 249, 0.99) 0%, rgba(255, 246, 236, 0.98) 100%);
  border: 1rpx solid rgba(217, 124, 98, 0.08);
  box-shadow:
    0 14rpx 28rpx rgba(52, 42, 36, 0.06),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  position: relative;
  overflow: hidden;
}

.entry-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.34), transparent 44%);
  pointer-events: none;
}

.entry-card::after {
  content: "";
  position: absolute;
  width: 220rpx;
  height: 220rpx;
  right: -80rpx;
  top: -100rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(242, 175, 116, 0.08) 0%, rgba(242, 175, 116, 0) 70%);
  pointer-events: none;
}

.entry-copy {
  flex: 1;
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.entry-desc {
  font-size: 22rpx;
  line-height: 1.55;
  color: var(--text-secondary);
  max-width: 336rpx;
  margin-top: 8rpx;
}

.entry-title {
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.entry-tag {
  padding: 8rpx 12rpx;
  border-radius: var(--radius-pill);
  background: rgba(217, 124, 98, 0.08);
  color: var(--color-primary);
  font-size: 18rpx;
}

.entry-button {
  width: 92rpx;
  height: 112rpx;
  padding: 0;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at top left, rgba(255, 208, 155, 0.22), transparent 30%),
    linear-gradient(160deg, #EE9E6A 0%, #E3845D 56%, #DA795B 100%);
  box-shadow:
    0 8rpx 14rpx rgba(217, 124, 98, 0.16),
    inset 0 1rpx 0 rgba(255, 247, 240, 0.26);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
  overflow: hidden;
}

.entry-button::before {
  content: "";
  position: absolute;
  inset: 7rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 244, 234, 0.12);
}

.entry-button::after {
  border: none;
}

.entry-button:active {
  transform: translateY(2rpx) scale(0.985);
}

.entry-button-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 100%;
  height: 100%;
}

.entry-button-text {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.1;
  color: var(--text-inverse);
  text-align: center;
}

.entry-button-arrow {
  font-size: 30rpx;
  line-height: 1;
  color: var(--text-inverse);
}

.import-prompt {
  margin-top: 30rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.import-map-link {
  margin-top: 6rpx;
  width: 100%;
  justify-content: center;
  font-size: 28rpx;
}

.drawer-layer {
  position: fixed;
  inset: 0;
  z-index: 40;
  pointer-events: none;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background: rgba(52, 42, 36, 0);
  transition: background 180ms ease;
}

.drawer-panel {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 78vh;
  padding: 18rpx 24rpx 28rpx;
  border-radius: 34rpx 34rpx 0 0;
  background: linear-gradient(180deg, #FFFDF9 0%, #FBF3E8 100%);
  box-shadow: var(--shadow-floating);
  transform: translateY(100%);
  transition: transform 220ms ease;
  display: flex;
  flex-direction: column;
}

.drawer-open {
  pointer-events: auto;
}

.drawer-open .drawer-mask {
  background: rgba(52, 42, 36, 0.34);
}

.drawer-open .drawer-panel {
  transform: translateY(0);
}

.drawer-handle {
  width: 96rpx;
  height: 8rpx;
  border-radius: var(--radius-pill);
  background: rgba(170, 154, 138, 0.45);
  margin: 0 auto 18rpx;
}

.drawer-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.drawer-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.drawer-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-secondary);
}

.drawer-close {
  padding: 10rpx 18rpx;
  border-radius: var(--radius-pill);
  background: rgba(217, 124, 98, 0.1);
  color: var(--color-primary);
  font-size: 22rpx;
}

.drawer-scroll {
  flex: 1;
  min-height: 0;
  padding-bottom: 24rpx;
}

.flow-step + .flow-step {
  margin-top: 22rpx;
}

.step-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.picker-value {
  height: 88rpx;
  border-radius: 22rpx;
  background: var(--bg-soft);
  border: 1rpx solid rgba(217, 124, 98, 0.12);
  padding: 0 22rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.picker-arrow {
  color: var(--text-tertiary);
}

.text-area {
  width: 100%;
  min-height: 300rpx;
  background: var(--bg-soft);
  border: 1rpx solid rgba(217, 124, 98, 0.12);
  border-radius: 22rpx;
  padding: 22rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.flow-bridge {
  margin: 24rpx 0 18rpx;
  font-size: 22rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.image-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.image-slot {
  width: 206rpx;
  height: 206rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.upload-slot {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-soft);
  border: 1rpx dashed rgba(217, 124, 98, 0.32);
}

.upload-plus {
  font-size: 40rpx;
  line-height: 1;
  color: var(--color-primary);
  margin-bottom: 10rpx;
}

.upload-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filled-slot {
  position: relative;
  background: var(--bg-soft);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-button {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  height: 50rpx;
  line-height: 50rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  margin: 0;
  padding: 0 16rpx;
  background: rgba(52, 42, 36, 0.75);
  color: var(--text-inverse);
}

.remove-button::after {
  border: none;
}

.inline-status {
  border-radius: 22rpx;
  padding: 20rpx 22rpx;
  margin-top: 22rpx;
}

.inline-status-warm {
  background: rgba(200, 155, 72, 0.1);
  border: 1rpx solid rgba(200, 155, 72, 0.14);
}

.inline-status-error {
  background: rgba(201, 125, 119, 0.1);
  border: 1rpx solid rgba(201, 125, 119, 0.16);
}

.inline-status-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.error-text {
  color: var(--color-danger);
  font-size: 26rpx;
  line-height: 1.5;
}

.flow-submit {
  margin-top: 26rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
}

@keyframes hotpotFloat {
  0%, 100% {
    transform: rotate(-7deg) translate3d(0, 0, 0);
  }
  50% {
    transform: rotate(-7deg) translate3d(0, -8rpx, 0);
  }
}

@keyframes skewerFloat {
  0%, 100% {
    transform: translate3d(0, 0, 0);
  }
  50% {
    transform: translate3d(0, -10rpx, 0);
  }
}

@keyframes dessertFloat {
  0%, 100% {
    transform: rotate(7deg) translate3d(0, 0, 0);
  }
  50% {
    transform: rotate(7deg) translate3d(0, -7rpx, 0);
  }
}

@keyframes tagBreath {
  0%, 100% {
    transform: scale(1);
    opacity: 0.96;
  }
  50% {
    transform: scale(1.04);
    opacity: 1;
  }
}

@keyframes glowPulse {
  0%, 100% {
    opacity: 0.55;
    transform: scale(0.96);
  }
  50% {
    opacity: 0.88;
    transform: scale(1.06);
  }
}

@keyframes warmthShift {
  0%, 100% {
    transform: translate3d(0, 0, 0);
    opacity: 0.52;
  }
  50% {
    transform: translate3d(18rpx, 10rpx, 0);
    opacity: 0.74;
  }
}

@keyframes sheenDrift {
  0%, 100% {
    opacity: 0.58;
    transform: translate3d(0, 0, 0);
  }
  50% {
    opacity: 0.9;
    transform: translate3d(-18rpx, 8rpx, 0);
  }
}

@keyframes steamRise {
  0%, 100% {
    opacity: 0.24;
    transform: translate3d(0, 10rpx, 0) scale(0.94);
  }
  50% {
    opacity: 0.72;
    transform: translate3d(0, -6rpx, 0) scale(1.02);
  }
}

@keyframes emberPulse {
  0%, 100% {
    opacity: 0.48;
    transform: scale(0.94);
  }
  50% {
    opacity: 0.9;
    transform: scale(1.06);
  }
}

@keyframes sparkBlink {
  0%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  45% {
    opacity: 1;
    transform: scale(1.1);
  }
}
