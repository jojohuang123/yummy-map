.layer-middle {
  background: linear-gradient(180deg, #FFD0DC 0%, #F6B7C8 100%);
}

.layer-bottom {
  background: linear-gradient(180deg, #FFF4F7 0%, #FEE7EE 100%);
}

.dessert-jam {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 62rpx;
  height: 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(255, 196, 213, 0), rgba(253, 165, 194, 0.72), rgba(255, 196, 213, 0));
}

.berry {
  position: absolute;
  top: 20rpx;
  width: 20rpx;
