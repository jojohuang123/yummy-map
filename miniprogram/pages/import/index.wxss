.picker-value {
  height: 84rpx;
  border-radius: var(--radius-md);
  background: var(--bg-soft);
  padding: 0 22rpx;
  line-height: 84rpx;
  font-size: 28rpx;
  color: var(--text-primary);
}

.dev-card {
  background: var(--bg-soft);
}

.dev-card .muted-text + .muted-text {
  margin-top: 8rpx;
}

.text-area {
  width: 100%;
  min-height: 280rpx;
  background: var(--bg-soft);
  border-radius: var(--radius-md);
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
}

.image-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.image-slot {
  width: 206rpx;
  height: 206rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
}

.upload-slot {
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-soft);
}

.upload-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.filled-slot {
  position: relative;
  background: var(--bg-soft);
}

.preview-image {
  width: 100%;
  height: 100%;
}

.remove-button {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  height: 50rpx;
  line-height: 50rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  margin: 0;
  padding: 0 16rpx;
  background: rgba(52, 42, 36, 0.75);
  color: var(--text-inverse);
}

.remove-button::after {
  border: none;
}

.status-card {
  background: var(--bg-soft);
}

.status-card .section-title {
  margin-bottom: 10rpx;
}

.status-card .muted-text {
  color: var(--text-secondary);
}

.error-card {
  background: var(--color-primary-soft);
}

.error-card .section-title {
  margin-bottom: 10rpx;
}

.error-text {
  color: var(--danger-soft);
  font-size: 26rpx;
  line-height: 1.5;
}

.import-map-link {
  margin-top: 18rpx;
}
