  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #FF8CAC 0%, #F05783 62%, #D13A64 100%);
  box-shadow: inset -4rpx -4rpx 6rpx rgba(143, 28, 60, 0.16);
}

.berry-one {
  left: 42rpx;
}

.berry-two {
