page {
  background: #f8f8f8;
  color: #333333;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.section-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.muted-text {
  color: #999;
  font-size: 24rpx;
}

.primary-button {
  background: #07C160;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}

.primary-button::after {
  border: none;
}

.primary-button:active {
  background: #06AD56;
}

.secondary-button {
  background: #f2f2f2;
  color: #07C160;
  border-radius: 8rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  border: none;
  text-align: center;
}
.secondary-button:active {
  background: #e6e6e6;
}

.tag-label {
  color: #07C160;
  font-size: 24rpx;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.cost-label {
  color: #999;
  font-size: 24rpx;
}

.card-title-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
