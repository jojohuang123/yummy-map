page {
  /* ===== 背景色系 ===== */
  --bg-page: #F7F2EA;
  --bg-card: #FFFDF9;
  --bg-soft: #F1E8DD;
  --bg-white: #FFFFFF;

  /* ===== 边框色系 ===== */
  --line-soft: #E6D9CB;
  --line-strong: #D9C9B9;
  --line-disabled: #E2D6CA;

  /* ===== 文字色系 ===== */
  --text-primary: #342A24;
  --text-secondary: #7A6A5C;
  --text-tertiary: #AA9A8A;
  --text-inverse: #FFFFFF;
  --text-disabled: #B8AA9C;

  /* ===== 主色 (Warm Coral) ===== */
  --color-primary: #D97C62;
  --color-primary-hover: #C96E55;
  --color-primary-soft: rgba(217, 124, 98, 0.12);
  --color-primary-muted: rgba(217, 124, 98, 0.35);

  /* ===== 辅助色 (Honey Gold) ===== */
  --color-score: #C89B48;
  --color-score-soft: rgba(200, 155, 72, 0.14);

  /* ===== 功能色 ===== */
  --color-success: #78A58B;
  --color-danger: #C97D77;

  /* ===== 阴影 ===== */
  --shadow-card: 0 8rpx 22rpx rgba(52, 42, 36, 0.06);
  --shadow-floating: 0 -8rpx 24rpx rgba(52, 42, 36, 0.08);
  --shadow-primary: 0 6rpx 20rpx rgba(217, 124, 98, 0.28);

  /* ===== 圆角 ===== */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 18rpx;
  --radius-lg: 26rpx;
  --radius-xl: 32rpx;
  --radius-pill: 999rpx;

  /* ===== 间距 ===== */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;

  /* ===== 页面基础设置 ===== */
  background: var(--bg-page);
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  line-height: 1.5;
}

.page-shell {
  min-height: 100vh;
  padding: 28rpx 24rpx 32rpx;
  box-sizing: border-box;
  background: var(--bg-page);
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.18;
  margin-bottom: 10rpx;
  letter-spacing: -0.5rpx;
}

.page-subtitle {
  font-size: 26rpx;
  line-height: 1.58;
  color: var(--text-secondary);
  margin-bottom: 28rpx;
}

/* ===== 卡片样式 ===== */
.section-card {
  background: var(--bg-card);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.muted-text {
  font-size: 24rpx;
  line-height: 1.55;
  color: var(--text-tertiary);
}

/* ===== 主按钮 ===== */
.primary-button {
  background: var(--color-primary);
  color: var(--text-inverse);
  border-radius: var(--radius-pill);
  font-size: 30rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border: none;
  box-shadow: var(--shadow-primary);
}

.primary-button::after {
  border: none;
}

.primary-button:active {
  background: var(--color-primary-hover);
  transform: scale(0.98);
}

.primary-button[disabled] {
  background: var(--line-strong);
  color: var(--text-disabled);
}

/* ===== 次要按钮 ===== */
.secondary-button {
  background: var(--bg-card);
  color: var(--text-secondary);
  border: 1rpx solid var(--line-strong);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  padding: 0 24rpx;
}

.secondary-button::after {
  border: none;
}

.secondary-button:active {
  background: var(--bg-soft);
}

/* ===== 危险按钮 ===== */
.danger-button {
  background: var(--bg-white);
  color: var(--color-danger);
  border: 1rpx solid var(--color-primary-muted);
  border-radius: var(--radius-pill);
  font-size: 26rpx;
  height: 68rpx;
  line-height: 68rpx;
  text-align: center;
}

.danger-button::after {
  border: none;
}

.danger-button:active {
  background: var(--color-primary-soft);
}

.danger-button[disabled] {
  background: var(--bg-soft);
  color: var(--text-disabled);
  border-color: var(--line-disabled);
}

/* ===== 文字按钮 ===== */
.text-button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
  color: var(--text-secondary);
  font-size: 26rpx;
  line-height: 1.4;
}

.text-button-accent {
  color: var(--color-primary);
}

/* ===== 标签样式 ===== */
.tag-label {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-pill);
  background: var(--bg-soft);
  color: var(--text-secondary);
  font-size: 22rpx;
}

.cost-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-primary);
}

/* ===== 评分徽章 ===== */
.rating-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44rpx;
  padding: 0 14rpx;
  border-radius: var(--radius-pill);
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
}

.rating-gold {
  background: var(--color-score-soft);
  color: #8E6925;
}

.rating-green {
  background: rgba(120, 165, 139, 0.15);
  color: #5F7C6A;
}

.rating-gray {
  background: var(--bg-soft);
  color: var(--text-secondary);
}

.rating-top {
  background: linear-gradient(180deg, #F2C35A 0%, #DCA240 100%);
  color: #FFF9EE;
}

.rating-high {
  background: linear-gradient(180deg, #F19B53 0%, #DF7E42 100%);
  color: #FFF9F0;
}

.rating-mid {
  background: rgba(217, 124, 98, 0.16);
  color: #A65C47;
}

.rating-low {
  background: var(--bg-soft);
  color: var(--text-secondary);
}

/* ===== 卡片头部组 ===== */
.card-title-group {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

/* ===== 搜索框 ===== */
.search-bar {
  display: flex;
  align-items: center;
  gap: 10rpx;
  min-height: 72rpx;
  padding: 0 20rpx;
  background: var(--bg-soft);
  border: 1rpx solid transparent;
  border-radius: var(--radius-pill);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-input::placeholder {
  color: var(--text-tertiary);
}

.search-clear {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text-tertiary);
  font-size: 20rpx;
}

/* ===== 城市选择器胶囊 ===== */
.city-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 22rpx;
  background: var(--bg-card);
  border: 1rpx solid var(--line-strong);
  border-radius: var(--radius-pill);
  color: var(--text-primary);
  font-size: 28rpx;
}

.city-pill:active {
  background: var(--bg-soft);
}

.picker-arrow {
  margin-left: 8rpx;
  font-size: 18rpx;
  color: var(--text-tertiary);
}

/* ===== 复选框 ===== */
.checkbox {
  width: 40rpx;
  height: 40rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1rpx solid var(--line-strong);
  background: var(--bg-white);
  color: transparent;
  font-size: 22rpx;
  flex-shrink: 0;
}

.checkbox-checked {
  border-color: var(--color-primary);
  background: var(--color-primary);
  color: var(--text-inverse);
}

.checkbox-disabled {
  background: var(--bg-soft);
  border-color: var(--line-disabled);
}

/* ===== 分隔线 ===== */
.divider {
  border: none;
  border-top: 1rpx solid var(--line-soft);
  margin: 16rpx 0;
}

.dotted-divider {
  border: none;
  border-top: 1rpx dashed var(--line-soft);
  margin: 16rpx 0;
}

/* ===== 高亮数字 ===== */
.highlight-count {
  color: var(--color-primary);
  font-weight: 600;
}

.highlight-count-small {
  color: var(--color-score);
  font-weight: 600;
}

/* ===== 统计栏 ===== */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--line-soft);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stats-bar .icon {
  margin-right: 6rpx;
}

/* ===== 空状态 ===== */
.empty-card {
  text-align: center;
  padding: 64rpx 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1rpx dashed var(--line-strong);
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

/* ===== 批量操作栏 ===== */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.batch-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.batch-delete-btn {
  background: var(--bg-white);
  color: var(--color-danger);
  border: 1rpx solid var(--color-primary-muted);
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
}

.batch-delete-btn[disabled] {
  background: var(--bg-soft);
  color: var(--text-disabled);
  border-color: var(--line-disabled);
}

/* ===== 列表头部 ===== */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.edit-toggle {
  font-size: 28rpx;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

/* ===== 卡片行 ===== */
.card-row {
  display: flex;
  align-items: flex-start;
}

.list-checkbox {
  margin-right: 16rpx;
}

/* ===== 详情行 ===== */
.detail-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.detail-address {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.import-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

/* ===== 按钮行 ===== */
.button-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.card-button {
  flex: 1;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
}

/* ===== 底部固定栏 ===== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 24rpx;
  border-top: 1rpx solid var(--line-soft);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 99;
  box-shadow: var(--shadow-floating);
}

.footer-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.footer-button {
  width: 40%;
  margin: 0;
}

/* ===== 摘要卡片 ===== */
.summary-card {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 0;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--line-soft);
  margin-bottom: 24rpx;
}

.summary-item {
  text-align: center;
}

.summary-val {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-primary);
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 筛选标签组 ===== */
.chip-row {
  margin-bottom: 16rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.chip {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  background: var(--bg-soft);
  color: var(--text-secondary);
  border: 1rpx solid transparent;
  border-radius: var(--radius-md);
  transition: all 0.2s ease;
}

.chip.active {
  background: var(--color-primary-soft);
  color: var(--color-primary);
  border-color: var(--color-primary-muted);
}

.chip:active {
  background: var(--line-soft);
}

.action-chip {
  background: var(--bg-card);
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
}

.action-chip:active {
  background: var(--color-primary-soft);
}
