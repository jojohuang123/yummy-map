/* ============================================
   美食地图助手 - 全局样式 (精致可爱美食家手帐风格)
   ============================================ */

/* ===== CSS 变量定义 ===== */
page {
  /* 背景色 */
  --bg-primary: #FFF8F0;
  --bg-card: #FFFCF9;

  /* 主色调 - 珊瑚橘色系 */
  --color-coral: #FF7B6B;
  --color-coral-light: #FFB4A2;
  --color-coral-dark: #E86B5B;

  /* 高亮色 - 蜂蜜金 */
  --color-honey: #FFAA33;
  --color-honey-gold: #FFB833;
  --color-honey-dark: #FF9500;

  /* 文字色 */
  --text-primary: #4A3728;
  --text-secondary: #8B7355;
  --text-muted: #B8A99A;

  /* 功能色 */
  --color-mint: #5BC8AF;
  --color-strawberry: #FF6B6B;

  /* 边框色 */
  --border-light: #FFE4DC;
  --border-coral: rgba(255, 123, 107, 0.3);

  /* 阴影 */
  --shadow-soft: 0 4rpx 16rpx rgba(255, 123, 107, 0.12);
  --shadow-card: 0 8rpx 32rpx rgba(74, 55, 40, 0.08);
  --shadow-coral: 0 8rpx 24rpx rgba(255, 123, 107, 0.3);
  --shadow-honey: 0 4rpx 12rpx rgba(255, 149, 0, 0.3);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-pill: 40rpx;

  /* 背景 */
  background: var(--bg-primary);
  color: var(--text-primary);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: var(--bg-primary);
}

.page-title {
  font-size: 44rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 24rpx;
  line-height: 1.5;
}

/* ===== 卡片样式 ===== */
.section-card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-card);
  border: 2rpx solid var(--border-light);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: var(--text-primary);
}

.muted-text {
  color: var(--text-muted);
  font-size: 24rpx;
}

/* ===== 主按钮 - 珊瑚色胶囊按钮 ===== */
.primary-button {
  background: linear-gradient(135deg, var(--color-coral), var(--color-coral-light));
  color: #FFFFFF;
  border-radius: var(--radius-pill);
  font-size: 32rpx;
  font-weight: 600;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  box-shadow: var(--shadow-coral);
}

.primary-button::after {
  border: none;
}

.primary-button:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(255, 123, 107, 0.2);
}

/* ===== 次要按钮 ===== */
.secondary-button {
  background: var(--bg-card);
  color: var(--color-coral);
  border-radius: var(--radius-md);
  font-size: 26rpx;
  height: 72rpx;
  line-height: 72rpx;
  border: 2rpx solid var(--color-coral);
  text-align: center;
  padding: 0 24rpx;
}

.secondary-button::after {
  border: none;
}

.secondary-button:active {
  background: rgba(255, 123, 107, 0.08);
}

/* ===== 危险按钮 ===== */
.danger-button {
  background: var(--color-strawberry);
  color: #FFFFFF;
  border-radius: var(--radius-md);
  font-size: 28rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}

.danger-button::after {
  border: none;
}

.danger-button[disabled] {
  background: #D4CBC0;
}

/* ===== 标签样式 ===== */
.tag-label {
  color: var(--text-secondary);
  font-size: 24rpx;
  background: rgba(255, 123, 107, 0.1);
  padding: 6rpx 16rpx;
  border-radius: var(--radius-sm);
  margin-right: 16rpx;
  display: inline-block;
}

.cost-label {
  color: var(--color-strawberry);
  font-size: 24rpx;
  font-weight: 500;
}

/* ===== 评分徽章 - 蜂蜜金色 ===== */
.rating-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  font-weight: 600;
}

.rating-badge::before {
  content: '⭐';
  font-size: 20rpx;
}

.rating-gold {
  background: linear-gradient(135deg, var(--color-honey-gold), var(--color-honey-dark));
  color: #FFFFFF;
  box-shadow: var(--shadow-honey);
}

.rating-green {
  background: linear-gradient(135deg, var(--color-mint), #4AB89C);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(91, 200, 175, 0.3);
}

.rating-gray {
  background: linear-gradient(135deg, #E8E0D8, #D4CBC0);
  color: var(--text-secondary);
  box-shadow: none;
}

/* ===== 卡片头部组 ===== */
.card-title-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* ===== 胶囊形小控件 ===== */
.city-pill {
  display: inline-flex;
  align-items: center;
  padding: 0 24rpx;
  height: 64rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--color-coral);
  border-radius: 36rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-shadow: var(--shadow-soft);
}

.picker-arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--color-coral);
}

/* ===== 搜索框 ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: #F5F0EB;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 72rpx;
  gap: 12rpx;
}

.search-icon {
  font-size: 28rpx;
  color: var(--color-coral);
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-clear {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

/* ===== 复选框 ===== */
.checkbox {
  font-size: 28rpx;
  border: 2rpx solid var(--border-light);
  width: 44rpx;
  height: 44rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: var(--bg-card);
  transition: all 0.2s ease;
}

.checkbox-checked {
  background: var(--color-coral);
  border-color: var(--color-coral);
  color: white;
}

.checkbox-disabled {
  background: #F5F0EB;
  border-color: #E8E0D8;
}

/* ===== 装饰性虚线分隔 ===== */
.dotted-divider {
  border: none;
  border-top: 2rpx dashed var(--border-light);
  margin: 16rpx 0;
}

/* ===== 高亮数字 ===== */
.highlight-count {
  color: var(--color-coral);
  font-weight: bold;
}

.highlight-count-small {
  color: var(--color-honey);
  font-weight: bold;
}

/* ===== 统计栏样式 ===== */
.stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-card);
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border-light);
  font-size: 26rpx;
  color: var(--text-secondary);
}

.stats-bar .icon {
  margin-right: 8rpx;
}

/* ===== 空状态 ===== */
.empty-card {
  text-align: center;
  padding: 64rpx 32rpx;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx dashed var(--border-light);
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

/* ===== 批量操作栏 ===== */
.batch-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  margin-bottom: 16rpx;
}

.batch-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.batch-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.batch-delete-btn {
  background: var(--color-strawberry);
  color: #fff;
  font-size: 26rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  margin: 0;
  border-radius: var(--radius-md);
}

.batch-delete-btn[disabled] {
  background: #D4CBC0;
}

/* ===== 列表头部 ===== */
.list-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.edit-toggle {
  font-size: 28rpx;
  color: var(--color-coral);
  padding: 8rpx 16rpx;
}

/* ===== 卡片行 ===== */
.card-row {
  display: flex;
  align-items: flex-start;
}

.list-checkbox {
  margin-right: 16rpx;
}

/* ===== 详情行 ===== */
.detail-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.detail-address {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.import-time {
  font-size: 22rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

/* ===== 按钮行 ===== */
.button-row {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.card-button {
  flex: 1;
  font-size: 24rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
}

/* ===== 底部固定栏 ===== */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  padding: 24rpx;
  border-top: 2rpx solid var(--border-light);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 99;
  box-shadow: 0 -4rpx 20rpx rgba(255, 123, 107, 0.08);
}

.footer-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.footer-button {
  width: 40%;
  margin: 0;
}

/* ===== 摘要卡片 ===== */
.summary-card {
  display: flex;
  justify-content: space-around;
  padding: 28rpx 0;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2rpx solid var(--border-light);
  margin-bottom: 24rpx;
}

.summary-item {
  text-align: center;
}

.summary-val {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-coral);
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ===== 筛选标签组 ===== */
.chip-row {
  margin-bottom: 16rpx;
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.chip {
  border-radius: var(--radius-md);
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  background: #F5F0EB;
  color: var(--text-secondary);
  border: 1rpx solid transparent;
  transition: all 0.2s ease;
}

.chip.active {
  background: rgba(255, 123, 107, 0.12);
  color: var(--color-coral);
  border-color: var(--color-coral);
}

.action-chip {
  background: var(--bg-card);
  border: 2rpx solid var(--color-coral);
  color: var(--color-coral);
}

.action-chip:active {
  background: rgba(255, 123, 107, 0.08);
}
